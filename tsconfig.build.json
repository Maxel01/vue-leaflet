{
  "extends": "./tsconfig.json",
  "include": [
    "src",
    "tests",
    "tests/**/*.json"
  ],
  "exclude": [
    "src/playground"
  ],
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist",
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler"
  }
}
